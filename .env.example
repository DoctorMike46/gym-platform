# ============================================================================
# Gym Platform — Esempio variabili d'ambiente
# ----------------------------------------------------------------------------
# Copia questo file in `.env` (o `.env.local`) e sostituisci i valori
# placeholder con quelli reali del tuo ambiente.
#
# In produzione (Vercel): configura le stesse variabili da Settings > Env Vars.
# ============================================================================

# ----- Database (Neon in prod, Postgres locale in dev) ----------------------
# Obbligatoria. Connection string PostgreSQL.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ----- Autenticazione JWT ---------------------------------------------------
# Obbligatoria. Min 32 caratteri in produzione. Usa: `openssl rand -base64 48`
JWT_SECRET="change-me-with-a-long-random-string-min-32-chars"

# ----- URL pubblico app -----------------------------------------------------
# Obbligatoria. Usata in email transazionali, deep link, redirect.
# Dev: http://localhost:3000  |  Prod: https://tuo-dominio.it
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----- Email transazionali (Resend) -----------------------------------------
# Obbligatorie in produzione.
# Ottieni la API key da https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Indirizzo mittente — il dominio deve essere VERIFICATO su Resend (SPF/DKIM).
RESEND_FROM_EMAIL="info@tuodominio.it"

# ----- Storage file (Cloudflare R2, S3-compatible) --------------------------
# Obbligatorie. Crea il bucket e le credenziali su Cloudflare > R2.
R2_ACCOUNT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_BUCKET_NAME="gym-documents"

# ----- Cron job protezione (Vercel Cron) ------------------------------------
# Obbligatoria in produzione. Shared secret per autenticare le richieste cron.
# Genera con: `openssl rand -hex 32`
CRON_SECRET="change-me-with-a-long-random-string"

# ----- OpenAI (opzionale, per feature AI) -----------------------------------
# Se assente, le feature AI sono disabilitate.
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Override modelli (default: gpt-4o-mini per entrambi)
# OPENAI_TEXT_MODEL="gpt-4o-mini"
# OPENAI_VISION_MODEL="gpt-4o-mini"

# ----- Rate limiting (Upstash Redis, opzionale) -----------------------------
# Se assente, il rate limiter è un noop (pass-through).
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ----- Push notifications (Firebase Cloud Messaging, opzionale) -------------
# Usa UNO dei due (preferito: _JSON inline su Vercel, _PATH in locale).
# Service account JSON inline (stringify del file scaricato da Firebase console).
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Oppure path al file JSON (utile in sviluppo locale).
# FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
